---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHead from '../components/PageHead.astro';
import work from '../data/work.json';
---

<BaseLayout
  title="Work Experience - Tsung-Min (Vincent) Pai"
  description="Work experience of Tsung-Min (Vincent) Pai — AI engineering roles at LOGOLO, Genibuilder, Compal Electronics, and Academia Sinica."
  path="/work"
>
  <PageHead name="work" />

  {work.map((job) => (
    <div class="card reveal">
      <h3>{job.role}, {job.org}</h3>
      <div class="meta">
        <span><span class="k">type:</span> {job.type}</span>
        <span><span class="k">period:</span> {job.period}</span>
        <span class="loc"><i class="fas fa-location-dot"></i> {job.location}</span>
        {job.extra && <span><span class="k">pi:</span> {job.extra.replace('Principal Investigator: ', '')}</span>}
      </div>
      <ul>
        {job.bullets.map((b) => <li>{b}</li>)}
      </ul>
    </div>
  ))}

  <div class="closing-bracket mono reveal">];</div>
</BaseLayout>

<style>
  .closing-bracket { font-size: 1.4rem; color: var(--text-dim); padding-bottom: 2rem; }
</style>
