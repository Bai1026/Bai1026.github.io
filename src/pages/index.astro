---
import BaseLayout from '../layouts/BaseLayout.astro';
import TerminalHero from '../components/TerminalHero.astro';
import news from '../data/news.json';
---

<BaseLayout
  title="About Me - Tsung-Min (Vincent) Pai"
  description="Tsung-Min (Vincent) Pai — AI engineer and researcher from National Taiwan University (NTU EE), focusing on Machine Learning, Generative AI, and Large Language Models."
  path="/"
>
  <TerminalHero />

  <section id="about-section" class="block reveal">
    <h2 class="section-title"><span class="comment">//</span> About Me</h2>
    <div class="about-grid">
      <div>
        <p>
          I am an undergraduate student at department of
          <a href="https://web.ee.ntu.edu.tw/" target="_blank">Electrical Engineering</a>,
          <a href="https://www.ntu.edu.tw/" target="_blank">National Taiwan University (NTU)</a>,
          focusing on Machine Learning, Generative AI, and Large Language Models.
        </p>
        <div class="social-row">
          <a href="mailto:b09602017@g.ntu.edu.tw" title="Email" class="social-icon"><i class="fas fa-envelope"></i></a>
          <a href="https://scholar.google.com/citations?hl=zh-TW&user=7Hq3tdcAAAAJ&view_op=list_works" target="_blank" title="Google Scholar" class="social-icon"><i class="fas fa-graduation-cap"></i></a>
          <a href="https://github.com/Bai1026" target="_blank" title="GitHub" class="social-icon"><i class="fab fa-github"></i></a>
          <a href="https://www.linkedin.com/in/tsung-ming-pai/" target="_blank" title="LinkedIn" class="social-icon"><i class="fab fa-linkedin"></i></a>
          <a href="/assets/documents/CV.pdf" target="_blank" title="CV" class="social-icon"><i class="fas fa-file-alt"></i></a>
        </div>
        <p class="contact-note">$ echo "Email and LinkedIn are the best way to reach me."</p>
      </div>
      <div class="codeblock">
        <div><span class="ln">1</span><span class="kw">const</span> <span class="id">vincent</span> = &#123;</div>
        <div><span class="ln">2</span>&nbsp;&nbsp;<span class="prop">education</span>: <span class="str">"NTU Electrical Engineering"</span>,</div>
        <div><span class="ln">3</span>&nbsp;&nbsp;<span class="prop">focus</span>: [<span class="str">"ML"</span>, <span class="str">"GenAI"</span>, <span class="str">"LLM"</span>],</div>
        <div><span class="ln">4</span>&nbsp;&nbsp;<span class="prop">role</span>: <span class="str">"AI Engineer @ LOGOLO"</span>,</div>
        <div><span class="ln">5</span>&nbsp;&nbsp;<span class="prop">hobby</span>: <span class="str">"basketball 🏀"</span>, <span class="cm">// vice captain</span></div>
        <div><span class="ln">6</span>&nbsp;&nbsp;<span class="prop">openToWork</span>: <span class="kw">true</span>,</div>
        <div><span class="ln">7</span>&#125;;</div>
      </div>
    </div>
  </section>

  <section id="news-section" class="block reveal">
    <h2 class="section-title"><span class="fn">git</span> log <span class="str">--news</span></h2>
    <div class="gitlog">
      {news.map((item) => (
        <div class={`commit ${item.milestone ? 'milestone' : ''}`}>
          <div class="commit-head">
            <span class="commit-hash">{item.hash}</span>
            <span class="commit-date">{item.date}</span>
          </div>
          <div class="commit-title">{item.title}</div>
          <div class="commit-desc" set:html={item.html} />
        </div>
      ))}
    </div>
  </section>

  <section id="contact-section" class="block reveal">
    <h2 class="section-title"><span class="comment">//</span> Let's Connect</h2>
    <p>Ready to collaborate or discuss exciting opportunities? I'd love to hear from you!</p>
    <a href="mailto:b09602017@g.ntu.edu.tw" class="btn btn-primary">
      <i class="fas fa-envelope"></i><span>mail -s "hello" vincent</span>
    </a>
  </section>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.4rem;
    align-items: center;
  }
  @media (max-width: 900px) {
    .about-grid { grid-template-columns: 1fr; }
  }
</style>
